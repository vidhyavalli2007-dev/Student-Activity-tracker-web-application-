body{
font-family: Arial;
background:#f4f4f4;
margin:0;
padding:0;
}

header{
background:#0077cc;
color:white;
text-align:center;
padding:20px;
}

.container{
width:80%;
margin:auto;
background:white;
padding:20px;
margin-top:20px;
border-radius:8px;
}

ul{
list-style:none;
padding:0;
}

li{
display:flex;
justify-content:space-between;
padding:10px;
border-bottom:1px solid #ddd;
}

button{
padding:6px 12px;
background:orange;
border:none;
color:white;
border-radius:4px;
cursor:pointer;
}

button.completed{
background:green;
}

#progress{
text-align:center;
margin-top:20px;
}
